{"compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
},
"include": ["features/**/*.ts","src/**/*.ts","pages/**/*.ts","step-definitions/**/*.ts","support/**/*.ts"]
}